PORT=3000
NODE_ENV=development
SEO_AGENT_HOST_PORT=8011

# OpenAI + Google keys: use appsettings.json (see appsettings.example.json)
GITHUB_TOKEN=
GITHUB_REPO=owner/repository

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@example.com

# Optional: recipient for scheduled scan reports (defaults to EMAIL_USER)
REPORT_EMAIL_TO=

# Daily scan at 09:00 UTC (cron syntax)
CRON_SCHEDULE=0 9 * * *

# Crawler limits (use 0 = crawl every discoverable same-origin page)
MAX_PAGES_PER_SCAN=25
CRAWL_WORKERS=12
CRAWL_MAX_DEPTH=4
CRAWL_TIMEOUT_MS=12000
BROKEN_LINK_CHECK_CAP=200
SLOW_PAGE_MS=3000

# Optional: HTTPS URL of the Angular app — clickable logo in PDF reports & report emails (e.g. https://seo.example.com)
PUBLIC_APP_URL=

# SQLite path (legacy single-tenant mode when DATABASE_URL is unset)
DB_PATH=/app/data/seo-agent.db

# PostgreSQL — multi-tenant mode (companies, company_configs JSON, company-scoped scans)
# Option A: standard URL (encode special chars in password, e.g. @ → %40, ! → %21)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:6432/SEOAgent

# Option B: .NET / appsettings-style (same as ConnectionStrings:Hiperbrains)
# HIPERBRAINS_DATABASE=Server=HOST;Port=6432;Database=SEOAgent;User Id=USER;Password=SECRET;
HIPERBRAINS_DATABASE=
DATABASE_URL=

# JWT for signup/login sessions
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Auto-delete scans, issues, saved report JSON, and activity_log rows older than N days (0 = off)
DATA_RETENTION_DAYS=7
# Optional: cron for retention job (default 03:00 UTC daily)
# DATA_RETENTION_CRON=0 3 * * *
